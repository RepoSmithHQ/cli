{
  "name": "@reposmith/cli",
  "version": "1.2.2",
  "description": "Repo Smith command-line tool — manage your GitHub backups from the terminal.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "reposmith": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "publint": "publint",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run lint && npm test && npm run publint",
    "prepare": "npm run build",
    "release": "semantic-release"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RepoSmithHQ/cli.git"
  },
  "bugs": {
    "url": "https://github.com/RepoSmithHQ/cli/issues"
  },
  "homepage": "https://github.com/RepoSmithHQ/cli#readme",
  "author": "Repo Smith <support@reposmith.com>",
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "citty": "^0.2.2",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "semantic-release": "^25.0.5",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "github",
    "backup",
    "cli",
    "reposmith"
  ]
}
